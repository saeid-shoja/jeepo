# Monorepo — copy apps/api/.env.example to apps/api/.env for the API database.

# MiMo Code CLI (mimocode.jsonc) — copy .mimo-api-key.example to .mimo-api-key and paste your sk-... key.
# Token Plan keys (tp-...) need baseURL https://token-plan-cn.xiaomimimo.com/v1 instead.

# Web (apps/web/.env.local) — base URL may be host only; `/api` is appended automatically
NEXT_PUBLIC_API_URL="https://jeepo-api-h4d6.vercel.app/api"
NEXT_PUBLIC_SITE_URL="https://jeepo.ir"
