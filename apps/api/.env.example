# Required for API runtime and migrations (not needed for web-only Vercel deploys).
DATABASE_URL="postgresql://offroad:offroad@localhost:5432/offroad_shop?schema=public"
PORT=4000
JWT_SECRET="change-me-in-production"
JWT_EXPIRES_IN="7d"
RESEND_API_KEY="re_xxxxxxxx"
# Must be a verified domain in Resend (or onboarding@resend.dev for local testing).
# Do not use @gmail.com — Resend rejects unverified third-party domains.
MAIL_FROM="jeepoinfo@jeepo.ir"

# Vercel API project: set DATABASE_URL in Production env vars.
# Build runs `prisma migrate deploy` — tables must be reachable from Vercel at build time.
# After first deploy, confirm migrations applied: tables like Library, Product, Category exist.

# Comma-separated browser origins (no trailing slashes). Apex and www are both accepted.
# CORS_ORIGINS="http://localhost:3000,http://localhost:3001,https://www.jeepo.ir,https://admin.jeepo.ir"

# Set to "false" to disable Swagger UI at /api/docs
# SWAGGER_ENABLED=true

# Zibal payment gateway (https://gateway.zibal.ir)
# Sandbox: merchant "zibal" — Real: your merchant code from Zibal panel (required in production).
ZIBAL_MERCHANT="your-zibal-merchant-code"
# Public API base URL (no trailing slash). Also used for Telegram webhook URL.
# Live Zibal merchants reject callbacks on *.vercel.app — use a jeepo.ir subdomain that points to this API.
API_PUBLIC_URL="https://api.jeepo.ir"
# Optional override when API_PUBLIC_URL differs; must still be on jeepo.ir and reach this server.
# ZIBAL_CALLBACK_URL="https://api.jeepo.ir/api/payments/zibal/callback"
# Register the same callback URL in Zibal panel → درگاه → تنظیمات → آدرس callback
# Where to redirect the buyer after payment (no trailing slash)
WEB_URL="https://jeepo.ir"

# Telegram bot for user announcements (create via @BotFather)
# TELEGRAM_BOT_TOKEN="123456:ABC..."
# TELEGRAM_BOT_USERNAME="JeepoBot"
# Webhook secret (1–256 chars: A-Z, a-z, 0-9, _ and - only — no / + =)
# TELEGRAM_WEBHOOK_SECRET="jeepo-tg-webhook-change-me"
# Webhook URL: {API_PUBLIC_URL}/api/telegram/webhook
# Register once: curl "https://api.telegram.org/bot<TOKEN>/setWebhook?url=<API_PUBLIC_URL>/api/telegram/webhook&secret_token=<TELEGRAM_WEBHOOK_SECRET>"
